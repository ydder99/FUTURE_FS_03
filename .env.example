# ═══════════════════════════════════════════════════════════════
# Saffron & Sage — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────
# In production, set this to your domain
CORS_ORIGIN=*

# ── Email Configuration (Optional) ───────────────────────────
# Gmail example: host=smtp.gmail.com, port=587, secure=false
# Use an App Password for Gmail (not your regular password)
# Generate one at: https://myaccount.google.com/apppasswords

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Where to receive contact form notifications
NOTIFICATION_EMAIL=owner@saffronandsage.in
